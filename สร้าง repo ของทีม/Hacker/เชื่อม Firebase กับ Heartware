MAX30105 particleSensor;

#define BUFFER_LENGTH 100
#define FINGER_THRESHOLD 10000  // ไม่มีนิ้ว ~700, มีนิ้ว ~130000

uint32_t irBuffer[BUFFER_LENGTH];
uint32_t redBuffer[BUFFER_LENGTH];

int32_t spo2, heartRate;
int8_t validSPO2, validHeartRate;

// Moving average
#define AVG_SIZE 5
int32_t bpmHistory[AVG_SIZE];
int32_t spo2History[AVG_SIZE];
uint8_t histIndex = 0;
uint8_t histCount = 0;

// เพิ่มตัวแปร filter ไว้บนสุด
float filterIR = 0;
float filterRed = 0;
const float alpha = 0.5; // ยิ่งต่ำยิ่ง smooth

// ฟังก์ชัน filter
uint32_t applyFilter(float &f, uint32_t val) {
  f = alpha * f + (1.0 - alpha) * val;
  return (uint32_t)f;
}

void addHistory(int32_t bpm, int32_t sp) {
  bpmHistory[histIndex] = bpm;
  spo2History[histIndex] = sp;
  histIndex = (histIndex + 1) % AVG_SIZE;
  if (histCount < AVG_SIZE) histCount++;
}

float avgBPM() {
  float s = 0;
  for (uint8_t i = 0; i < histCount; i++) s += bpmHistory[i];
  return s / histCount;
}

float avgSpO2() {
  float s = 0;
  for (uint8_t i = 0; i < histCount; i++) s += spo2History[i];
  return s / histCount;
}

void connectWiFi() {
  WiFi.begin(ssid, password);
  Serial.print("Connecting WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected!");
}


void sendToFirebase(int bpm, int spo2, int status) {

  if (WiFi.status() != WL_CONNECTED) return;

  String url = firestoreUrl + "?key=" + String(API_KEY);

  http.begin(client, url);
  http.addHeader("Content-Type", "application/json");

  String json = "{ \"fields\": { "
              "\"bpm\": { \"integerValue\": " + String(bpm) + " }, "
              "\"spo2\": { \"integerValue\": " + String(spo2) + " }, "
              "\"status\": { \"integerValue\": " + String(status) + " }, "
              "\"timestamp\": { \"stringValue\": \"" + getTimeNow() + "\" }"
              "} }";

  int httpCode = http.POST(json);

  Serial.print("Firebase HTTP: ");
  Serial.println(httpCode);

  http.end();
}

String getTimeNow() {
  time_t now = time(nullptr);
  struct tm* p_tm = localtime(&now);

  char buffer[30];
  sprintf(buffer, "%04d-%02d-%02d %02d:%02d:%02d",
          p_tm->tm_year + 1900,
          p_tm->tm_mon + 1,
          p_tm->tm_mday,
          p_tm->tm_hour,
          p_tm->tm_min,
          p_tm->tm_sec);

  return String(buffer);
}

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  connectWiFi();

  client.setInsecure();

  configTime(7 * 3600, 0, "pool.ntp.org");

  Serial.print("Waiting for NTP time");

  while (time(nullptr) < 100000) {
    delay(500);
    Serial.print(".");
  }

  Serial.println(" OK");

  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    Serial.println("MAX30102 not found!");
    while (1);
  }



  particleSensor.setup(30, 4, 2, 50, 411, 4096);
  Serial.println("Ready. Place finger on sensor...");
  sendToFirebase(0, 0, 0); // READY
}

void loop() {
  // เก็บ buffer
  for (byte i = 0; i < BUFFER_LENGTH; i++) {
    while (!particleSensor.available())
      particleSensor.check();

    redBuffer[i] = applyFilter(filterRed, particleSensor.getRed());
    irBuffer[i]  = applyFilter(filterIR,  particleSensor.getIR());
    particleSensor.nextSample();
  }

  // เช็คนิ้ว
  if (irBuffer[BUFFER_LENGTH - 1] < FINGER_THRESHOLD) {
    Serial.println("[ No Finger ] วางนิ้วบนเซ็นเซอร์...");
    histCount = 0;
    histIndex = 0;
    sendToFirebase(0, 0, 1); // NO_FINGER
    delay(500);
    return;
  }

  // คำนวณครั้งแรก
  maxim_heart_rate_and_oxygen_saturation(
    irBuffer, BUFFER_LENGTH, redBuffer,
    &spo2, &validSPO2, &heartRate, &validHeartRate
  );

  while (1) {
    // sliding window
    for (byte i = 25; i < BUFFER_LENGTH; i++) {
      redBuffer[i - 25] = redBuffer[i];
      irBuffer[i - 25]  = irBuffer[i];
    }

    for (byte i = 75; i < BUFFER_LENGTH; i++) {
      while (!particleSensor.available())
        particleSensor.check();
      redBuffer[i] = particleSensor.getRed();
      irBuffer[i]  = particleSensor.getIR();
      particleSensor.nextSample();
    }

    // เช็คนิ้วหลุด
    if (irBuffer[BUFFER_LENGTH - 1] < FINGER_THRESHOLD) {
      Serial.println("[ No Finger ] นิ้วหลุด");
      histCount = 0;
      histIndex = 0;
      sendToFirebase(0, 0, 1); //
      break;
    }

    // คำนวณใหม่
    maxim_heart_rate_and_oxygen_saturation(
      irBuffer, BUFFER_LENGTH, redBuffer,
      &spo2, &validSPO2, &heartRate, &validHeartRate
    );

    // กรองและเก็บ history
    bool bpmOK  = validHeartRate && heartRate >= 40 && heartRate <= 180;
    bool spo2OK = validSPO2 && spo2 >= 85 && spo2 <= 100;

    if (bpmOK && spo2OK) {
  addHistory(heartRate, spo2);

  int bpmToSend  = (int)avgBPM();
  int spo2ToSend = (int)avgSpO2();

  Serial.println("--------------------");
  Serial.print("BPM  : "); Serial.println(bpmToSend);
  Serial.print("SpO2 : "); Serial.print(spo2ToSend);
  Serial.println(" %");
  Serial.println("--------------------");

  sendToFirebase(bpmToSend, spo2ToSend, 2); // MEASURING
}
  }
