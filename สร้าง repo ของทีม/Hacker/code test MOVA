#include <BLEDevice.h>
#include <BLEServer.h>
#include <BLEUtils.h>
#include <BLE2902.h>

#include <Wire.h>
#include <MPU6050.h>

MPU6050 mpu;

// ===== FSR Pins =====
#define FSR1 36
#define FSR2 39
#define FSR3 32
#define FSR4 33

// ===== BLE =====
BLECharacteristic *pCharacteristic;
bool deviceConnected = false;

#define SERVICE_UUID        "12345678-1234-1234-1234-1234567890ab"
#define CHARACTERISTIC_UUID "abcdefab-1234-1234-1234-abcdefabcdef"

// ===== sensor values =====
int fsr1, fsr2, fsr3, fsr4;
int16_t ax, ay, az, gx, gy, gz;

// ===== smoothing function =====
int smoothRead(int pin) {
  int total = 0;
  for (int i = 0; i < 5; i++) {
    total += analogRead(pin);
    delay(2);
  }
  return total / 5;
}

class MyServerCallbacks: public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) {
    deviceConnected = true;
    Serial.println("BLE Connected");
  }

  void onDisconnect(BLEServer* pServer) {
    deviceConnected = false;
    Serial.println("BLE Disconnected");
  }
};

void readSensors() {
  fsr1 = smoothRead(FSR1);
  fsr2 = smoothRead(FSR2);
  fsr3 = smoothRead(FSR3);
  fsr4 = smoothRead(FSR4);

  mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);
}

void setup() {
  Serial.begin(115200);

  pinMode(FSR1, INPUT);
  pinMode(FSR2, INPUT);
  pinMode(FSR3, INPUT);
  pinMode(FSR4, INPUT);

  Wire.begin();
  mpu.initialize();

  Serial.println(mpu.testConnection() ? "MPU OK" : "MPU FAIL");

  BLEDevice::init("MOVA_ESP32");

  BLEServer *server = BLEDevice::createServer();
  server->setCallbacks(new MyServerCallbacks());

  BLEService *service = server->createService(SERVICE_UUID);

  pCharacteristic = service->createCharacteristic(
                      CHARACTERISTIC_UUID,
                      BLECharacteristic::PROPERTY_NOTIFY
                    );

  pCharacteristic->addDescriptor(new BLE2902());

  service->start();
  BLEDevice::getAdvertising()->start();

  Serial.println("READY");
}

void loop() {
  readSensors();

  // ===== normalize ให้เห็นชัดขึ้น =====
  int n1 = map(fsr1, 0, 4095, 0, 100);
  int n2 = map(fsr2, 0, 4095, 0, 100);
  int n3 = map(fsr3, 0, 4095, 0, 100);
  int n4 = map(fsr4, 0, 4095, 0, 100);

  String data =
    "FSR1:" + String(n1) + "|" +
    "FSR2:" + String(n2) + "|" +
    "FSR3:" + String(n3) + "|" +
    "FSR4:" + String(n4) + "|" +
    "AX:" + String(ax) + "|" +
    "AY:" + String(ay) + "|" +
    "AZ:" + String(az) + "|" +
    "GX:" + String(gx) + "|" +
    "GY:" + String(gy) + "|" +
    "GZ:" + String(gz);

  Serial.println(data);

  if (deviceConnected) {
    pCharacteristic->setValue(data.c_str());
    pCharacteristic->notify();
  }

  delay(200);
}
